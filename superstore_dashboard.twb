            <column caption='Discount Band' datatype='string' name='[Calculation_1618762640107286528]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF { FIXED [Order ID] : MAX([Discount]) } = 0 THEN &quot;No Discount&quot;&#13;&#10;ELSEIF { FIXED [Order ID] : MAX([Discount]) } &lt;= 0.2 THEN &quot;Low (1-20%)&quot;&#13;&#10;ELSEIF { FIXED [Order ID] : MAX([Discount]) } &lt;= 0.4 THEN &quot;Medium (21-40%)&quot;&#13;&#10;ELSE &quot;High (41%+)&quot;&#13;&#10;END' />

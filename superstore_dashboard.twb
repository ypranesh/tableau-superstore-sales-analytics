      <aliases enabled='yes' />
      <column caption='Discount Band' datatype='string' name='[Calculation_1618762640107286528]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF { FIXED [Order ID] : MAX([Discount]) } = 0 THEN &quot;No Discount&quot;&#13;&#10;ELSEIF { FIXED [Order ID] : MAX([Discount]) } &lt;= 0.2 THEN &quot;Low (1-20%)&quot;&#13;&#10;ELSEIF { FIXED [Order ID] : MAX([Discount]) } &lt;= 0.4 THEN &quot;Medium (21-40%)&quot;&#13;&#10;ELSE &quot;High (41%+)&quot;&#13;&#10;END' />
      </column>
      <column caption='Avg Discount by Sub-Category' datatype='real' name='[Calculation_1618762640107597825]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Sub-Category] : AVG([Discount]) }' />
      </column>
      <column caption='Orders Per Customer' datatype='integer' name='[Calculation_1618762640115134466]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Customer ID] : COUNTD([Order ID]) }' />
      </column>
      <column caption='Order Frequency Band' datatype='string' name='[Calculation_1618762640115257347]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1618762640115134466] = 1 THEN &quot;1 Order&quot;&#13;&#10;ELSEIF [Calculation_1618762640115134466] = 2 THEN &quot;2 Orders&quot;&#13;&#10;ELSEIF [Calculation_1618762640115134466] = 3 THEN &quot;3 Orders&quot;&#13;&#10;ELSEIF [Calculation_1618762640115134466] &gt;= 4 THEN &quot;4+ Orders&quot;&#13;&#10;END' />
      </column>
      <column caption='Profit ratio' datatype='real' name='[Calculation_487514708036481024]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Profit]) / SUM([Sales])' />
      </column>
      <column caption='Customer First Order Date' datatype='date' name='[Calculation_496521907623411712]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='{ FIXED [Customer ID] : MIN([Order Date]) }' />
      </column>
      <column caption='Order Type' datatype='string' name='[Calculation_496521907623710721]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Order Date] = [Calculation_496521907623411712] &#13;&#10;THEN &quot;New Customer Revenue&quot;&#13;&#10;ELSE &quot;Repeat Customer Revenue&quot;&#13;&#10;END' />
      </column>
      <column caption='Revenue by Order Type' datatype='real' name='[Calculation_496521907623899138]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Calculation_496521907623710721] : SUM([Sales]) }' />
      </column>
